# Copy this file to `.env` and fill in the keys.

# Gemini via the OpenAI-compatible API — REQUIRED for real replies.
# Get a free key at https://aistudio.google.com/apikey
# (You can also set OPENAI_API_KEY instead — the server accepts either.)
GEMINI_API_KEY=

# Optional: override the model. Default is gemini-2.5-flash (fast + cheap).
# Use gemini-2.5-pro for the best persona fidelity.
GEMINI_MODEL=gemini-2.5-flash

# YouTube Data API v3 — REQUIRED for scraping comments/videos.
# Get one at https://console.cloud.google.com/ (enable "YouTube Data API v3")
YOUTUBE_API_KEY=

# Set to 1 to force MOCK mode (UI works with a canned reply, no LLM call).
# If GEMINI_API_KEY is empty, the server runs in MOCK mode automatically.
MOCK=0

# Backend port
PORT=8787
