# Copy this file to `.env` and fill in the keys.

# ---- OpenAI --- REQUIRED for real replies.
# Get a key at https://platform.openai.com/api-keys  (paid — no free tier).
OPENAI_API_KEY=
# Optional: override the model. Default is gpt-4o-mini (cheap + fast).
OPENAI_MODEL=gpt-4o-mini

# ---- Scraping --------------------------------------------------------------
# YouTube Data API v3 — REQUIRED only for scraping comments/videos (local, dev-time).
# Get one at https://console.cloud.google.com/ (enable "YouTube Data API v3")
YOUTUBE_API_KEY=

# ---- Misc ------------------------------------------------------------------
# Set to 1 to force MOCK mode (UI works with a canned reply, no LLM call).
# If OPENAI_API_KEY is empty, the server runs in MOCK mode automatically.
MOCK=0

# Backend port (local dev only)
PORT=8787
